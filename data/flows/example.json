{
  "name": "Example Flow",
  "version": 2,
  "templatesDir": "out",
  "functions": [
    {
      "id": "fn_back_home",
      "name": "Về Home",
      "graph": {
        "nodes": [
          { "id": "f_start", "type": "start", "x": 60,  "y": 80, "params": {} },
          { "id": "f_home",  "type": "home",  "x": 260, "y": 80, "params": {} },
          { "id": "f_wait",  "type": "wait",  "x": 460, "y": 80, "params": { "seconds": 0.5 } }
        ],
        "edges": [
          { "from": "f_start", "fromPort": "out", "to": "f_home" },
          { "from": "f_home",  "fromPort": "out", "to": "f_wait" }
        ]
      }
    }
  ],
  "activities": [
    {
      "id": "sequence_demo",
      "name": "Khởi động",
      "type": "sequence",
      "enabled": true,
      "maxRetries": 1,
      "graph": {
        "nodes": [
          { "id": "n_start", "type": "start",      "x": 60,  "y": 100, "params": {} },
          { "id": "n_call",  "type": "call",        "x": 240, "y": 100, "params": { "fn": "fn_back_home" } },
          { "id": "n_wait",  "type": "wait_image",  "x": 430, "y": 100, "params": { "template": "out/home.png", "threshold": 0.85, "timeout": 10 } },
          { "id": "n_if",    "type": "if_image",    "x": 650, "y": 60,  "params": { "template": "out/reward.png", "threshold": 0.85, "negate": false } },
          { "id": "n_tapf",  "type": "tap",         "x": 880, "y": 30,  "params": { "target": "found", "x": 0, "y": 0 } },
          { "id": "n_loop",  "type": "loop",        "x": 880, "y": 150, "params": { "count": 3 } },
          { "id": "n_tap",   "type": "tap",         "x": 1090,"y": 130, "params": { "target": "pos", "x": 540, "y": 1600 } },
          { "id": "n_w2",    "type": "wait",        "x": 1090,"y": 230, "params": { "seconds": 0.5 } },
          { "id": "n_end",   "type": "end",         "x": 650, "y": 260, "params": {} }
        ],
        "edges": [
          { "from": "n_start", "fromPort": "out",   "to": "n_call" },
          { "from": "n_call",  "fromPort": "out",   "to": "n_wait" },
          { "from": "n_wait",  "fromPort": "true",  "to": "n_if" },
          { "from": "n_wait",  "fromPort": "false", "to": "n_end" },
          { "from": "n_if",    "fromPort": "true",  "to": "n_tapf" },
          { "from": "n_if",    "fromPort": "false", "to": "n_loop" },
          { "from": "n_tapf",  "fromPort": "out",   "to": "n_loop" },
          { "from": "n_loop",  "fromPort": "body",  "to": "n_tap" },
          { "from": "n_tap",   "fromPort": "out",   "to": "n_w2" },
          { "from": "n_w2",    "fromPort": "out",   "to": "n_loop" },
          { "from": "n_loop",  "fromPort": "done",  "to": "n_end" }
        ]
      }
    },
    {
      "id": "background_collect",
      "name": "Nhặt thưởng nền",
      "type": "background",
      "enabled": true,
      "pollInterval": 2.0,
      "graph": {
        "nodes": [
          { "id": "b_start", "type": "start",     "x": 60,  "y": 80, "params": {} },
          { "id": "b_tap",   "type": "tap_image", "x": 260, "y": 80, "params": { "template": "out/reward.png", "threshold": 0.88, "timeout": 1 } }
        ],
        "edges": [
          { "from": "b_start", "fromPort": "out", "to": "b_tap" }
        ]
      }
    }
  ]
}
